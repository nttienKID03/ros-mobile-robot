  <!-- /////////////////////////transmission/////////////////////////-->
  <transmission name="left_wheel_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="left_wheel_joint">
        <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="left_motor">
        <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
        <mechanicalReduction>1.0</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="right_wheel_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="right_wheel_joint">
        <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="right_motor">
        <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
        <mechanicalReduction>1.0</mechanicalReduction>
   </actuator>
  </transmission>


  <!-- ///////////////////////gazebo////////////////////////-->
  <gazebo reference="linkphutren">
	<selfCollide>true</selfCollide>
  </gazebo>
  
  <gazebo reference="linkphuduoi">
	<selfCollide>true</selfCollide>
  </gazebo>
  
  <gazebo reference="left_wheel">
	<selfCollide>true</selfCollide>
  </gazebo>
  
  <gazebo reference="right_wheel">
	<selfCollide>true</selfCollide>
  </gazebo>

  <!-- Plugin quét lidar -->
  <gazebo reference="laser">
    <sensor type="ray" name="head_hokuyo_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate> 
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.1415</min_angle>
            <max_angle>3.1415</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_laser.so" name="gazebo_ros_head_hokuyo_controller">
        <topicName>/scan</topicName>
        <frameName>base_footprint</frameName>
      </plugin>
    </sensor>
  </gazebo>
  

  <gazebo reference="IMU">
    <sensor type="imu" name="imu_sensor">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>100.0</update_rate>
      <imu>
        <topicName>imu/data</topicName>
        <gaussianNoise>0.01</gaussianNoise>
      </imu>
      <plugin name="gazebo_ros_imu" filename="libgazebo_ros_imu_sensor.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>100.0</updateRate>
        <bodyName>IMU</bodyName>
        <topicName>imu/data</topicName>
        <gaussianNoise>0.01</gaussianNoise>
        <frameName>IMU</frameName>
      </plugin>
    </sensor>
  </gazebo>


  <gazebo reference="left_wheel_joint">
    <joint>
      <physics>
        <ode>
          <fudge_factor>0.1</fudge_factor>
          <limit>
            <cfm>0.0</cfm>
            <erp>0.2</erp>
          </limit>
          <axis>
            <limit>
              <effort>10.0</effort>
              <velocity>10.0</velocity>
            </limit>
          </axis>
       </ode>
      </physics>
    </joint>
  </gazebo>

  <gazebo reference="right_wheel_joint">
    <joint>
     <physics>
       <ode>
         <fudge_factor>0.1</fudge_factor>
          <limit>
           <cfm>0.0</cfm>
           <erp>0.2</erp>
          </limit>
          <axis>
           <limit>
             <effort>10.0</effort>
             <velocity>10.0</velocity>
           </limit>
          </axis>
        </ode>
      </physics>
   </joint>
  </gazebo>

  <gazebo reference="phuduoi">
    <joint>
      <physics>
        <ode>
          <limit>
            <cfm>0.000001</cfm>
            <erp>0.8</erp>
          </limit>
          <axis>
            <limit>
              <effort>50.0</effort>
              <velocity>15.0</velocity>
            </limit>
            <dynamics>
              <damping>0.5</damping>
              <friction>0.1</friction>
            </dynamics>
          </axis>
        </ode>
      </physics>
    </joint>
  </gazebo>



</robot>