<launch>
  <!-- Sử dụng move_base để điều hướng -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <param name="base_global_planner" value="navfn/NavfnROS"/>
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
    
    <rosparam file="$(find mobile)/config/dwa_local_planner_params.yaml" command="load"/>


    <!-- Frame -->
    <param name="global_frame_id" value="map"/>
    <param name="robot_base_frame" value="base_footprint"/>
    <param name="planner_frequency" value="4.0"/>
    <param name="controller_frequency" value="10.0"/>
    
    <!-- Load costmap -->
    <rosparam file="$(find mobile)/config/costmap_common_params.yaml" command="load"/>
    <rosparam file="$(find mobile)/config/local_costmap_params.yaml" command="load"/>
    <rosparam file="$(find mobile)/config/global_costmap_params.yaml" command="load"/>
  </node>

  <!-- Chạy node multi_goal_nav -->
  <!--node name="multi_goal_nav" pkg="mobile" type="multi_goal_nav.py" output="screen">
    <param name="waypoints_file" value="$(find mobile)/config/waypoints.yaml"/>
  </node-->


</launch>
